# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGEME@localhost:5432/legal_ai

# ─── File storage ──────────────────────────────────────────────────────────
FILE_PATH=./data/pdfs
SEMAPHORE=10

# ─── Local LLM (Ollama, for development) ───────────────────────────────────
OLLAMA_HOST=http://localhost:11434
EMBEDING_MODEL=bge-m3
GENERATION_MODEL=qwen2.5:7b
RERANKING_MODEL=BAAI/bge-reranker-v2-m3

# ─── LLM provider routing ──────────────────────────────────────────────────
# Choose: "ollama" (local) | "together" | "groq" | "openai" | "openrouter"
LLM_PROVIDER=ollama

# ─── Cloud LLM (for online demo) ──────────────────────────────────────────
# Together AI: https://api.together.xyz/
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Groq: https://console.groq.com/
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-70b-versatile

# OpenRouter: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-7b-instruct

# ─── OpenAI (for RAGAS evaluation only — not used in production pipeline) ──
OPENAI_API_KEY=

# ─── API server ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
